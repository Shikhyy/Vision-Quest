# ═══════════════════════════════════════════
# Vision Quest — Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your keys.
#   cp .env.example .env

# ── Gemini AI (Required for AI-powered NPC dialogue) ──
# Get your key at: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── Stream Video (Optional — enables real-time NPC video calls) ──
# Get your keys at: https://getstream.io/
VITE_STREAM_API_KEY=

# Token provider URL. In dev mode this is auto-provided by the Vite plugin.
# In production, point this to your backend token endpoint.
VITE_STREAM_TOKEN_URL=
